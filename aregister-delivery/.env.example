# MPQR A-Register OTP — REST API config (template). Copy to .env and fill in.
# ─────────────────────────────────────────────────────────────────────────────

# Server
PORT=3050
# The API key callers send in the X-API-Key header (and the tester uses).
# In production set a strong value via `fly secrets set MPQR_API_KEY=...`.
MPQR_API_KEY=change-me

# Playwright / Chromium
PLAYWRIGHT_HEADLESS=true
PLAYWRIGHT_TIMEOUT_MS=30000

# HARD cap on simultaneous headless browsers (~300 MB each) — the real memory guard.
# Keep >= warm pool size + peak concurrent verifications, or launches queue.
MPQR_MAX_CONCURRENT_BROWSERS=5
# Standing pre-launched browsers parked at the A-Register form → fast OTP send.
MPQR_WARM_POOL_SIZE=2
# Keep-alive interval (ms). 0 = OFF (recommended): the in-page ping corrupted the
# live government OTP session in testing. Leave 0 unless a safe approach is proven.
MPQR_KEEPALIVE_MS=0
# RSS ceiling (MB): the memory watchdog sheds new /start above this, then restarts
# cleanly once idle before the kernel OOM-kills. Keep under the VM's RAM.
MPQR_RSS_CEILING_MB=1700

# Logging (pino → stdout, JSON). debug | info | warn | error
LOG_LEVEL=info
