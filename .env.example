# MPQR Patta OTP — REST API config (template). Copy to .env and fill in.
# ──────────────────────────────────────────────────────────────────────
# A lean OTP → fetch → PDF REST service. No database, no S3, no session pool.

# Server
PORT=3030
# API key callers (MyPropertyQR) send in the X-API-Key header. Set a strong value
# in production via `fly secrets set MPQR_API_KEY=...`.
MPQR_API_KEY=change-me

# Playwright / Chromium
PLAYWRIGHT_HEADLESS=true
PLAYWRIGHT_TIMEOUT_MS=30000

# HARD cap on simultaneous headless browsers (each ~200-350 MB) — the real memory
# guard. Keep >= warm pool size + peak concurrent verifications, or launches queue.
MPQR_MAX_CONCURRENT_BROWSERS=6
# Standing pre-launched browsers parked at the govt form → fast OTP send.
MPQR_WARM_POOL_SIZE=3
# Keep-alive ping interval (ms). While a browser sits idle (warm pool, or holding a
# sent OTP while the customer reads the SMS), this touches the govt session so its
# server-side JSESSIONID never times out into an "INVALID ACCESS" page. Must be well
# under the govt idle timeout; 30s is safe. Min 5000.
MPQR_KEEPALIVE_MS=30000
# RSS ceiling (MB): memory watchdog sheds new /start above this, then restarts
# cleanly once idle before the kernel OOM-kills. Keep under the VM's RAM.
MPQR_RSS_CEILING_MB=1500

# Optional tuning (sane defaults if unset):
#   MPQR_POOL_TICK_MS=20000        warm-pool maintenance tick
#   MPQR_NETWORKIDLE_MS=800        best-effort settle after nav
#   MPQR_LAUNCH_TIMEOUT_MS=30000   hard cap on a single Chromium launch

# Logging (pino → stdout, JSON). debug | info | warn | error
LOG_LEVEL=info

# PDF front-page branding
PDF_BRAND_NAME=MyPropertyQR
PDF_BRAND_TAGLINE=Government of Tamil Nadu

# Logging
DEBUG=0

# ── REGISTER module (TNREGINET EC) — separate service: node register/server.js ──
# Captcha auto-solve via TrueCaptcha (apitruecaptcha.org). Set CAPTCHA_MODE=truecaptcha
# + both creds → Quick EC solves captchas itself (no human, works with an empty pool).
CAPTCHA_MODE=hitl
TRUECAPTCHA_USERID=
TRUECAPTCHA_APIKEY=
